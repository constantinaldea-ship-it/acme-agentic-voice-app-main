<mxfile host="app.diagrams.net">
  <diagram name="CX Agent Hybrid Template">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1"
      pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Internet -->
        <mxCell id="internet" value="Internet / Channels"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9d9d9;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1880" height="120" as="geometry"/>
        </mxCell>

        <!-- Google Managed -->
        <mxCell id="google" value="Google Managed (CX Agent Studio)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#d9d9d9;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="160" width="1880" height="160" as="geometry"/>
        </mxCell>

        <!-- Landing Zone -->
        <mxCell id="gcp" value="GCP Landing Zone"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9d9d9;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="340" width="1880" height="300" as="geometry"/>
        </mxCell>

        <!-- Hybrid -->
        <mxCell id="hybrid" value="Hybrid Connectivity"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#d9d9d9;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="660" width="1880" height="140" as="geometry"/>
        </mxCell>

        <!-- On Prem -->
        <mxCell id="onprem" value="On-Prem Datacenter"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9d9d9;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="820" width="1880" height="200" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
