# Repository-wide local configuration template
# Copy to .env and fill in values for your environment.

# Required for GCP deployment scripts in scripts/cloud/ and java/* deploy helpers
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCP_ZONE=europe-west1-b

# Required for CES import flows in ces-agent/scripts/deploy/deploy-agent.sh
# Use a CES location such as: us or eu
GCP_LOCATION=eu
CES_APP_ID=acme-voice-eu
CES_ENDPOINT=https://ces.eu.rep.googleapis.com

# Required for direct CES runtime session checks in ces-agent/voice-testing
# Use the API access deployment id from the CES Deploy > API access channel
CES_DEPLOYMENT_ID=your-ces-deployment-id

# Fee schedule datastore lifecycle for ces-agent/acme_voice_agent/agents/fee_schedule_agent
# Used by ces-agent/scripts/deploy/manage_datastore.sh and auto-invoked by
# ces-agent/scripts/deploy/deploy-agent.sh when the fee_schedule_agent is packaged.
FEE_SCHEDULE_DATASTORE_LOCATION=global
FEE_SCHEDULE_DATASTORE_COLLECTION=default_collection
FEE_SCHEDULE_DATASTORE_ID=fee-schedule-lookup_1771833548805
FEE_SCHEDULE_DATASTORE_DISPLAY_NAME=fee_schedule_lookup
FEE_SCHEDULE_BRANCH_ID=default_branch
FEE_SCHEDULE_BUCKET_URI=gs://your-gcp-project-id-fee-schedule
FEE_SCHEDULE_BUCKET_LOCATION=EU
FEE_SCHEDULE_SOURCE_URL=https://www.deutsche-bank.de/dam/deutschebank/de/shared/pdf/kontakt-und-service/list-of-prices-and-Services-deutsche-bank-ag.pdf
FEE_SCHEDULE_OBJECT_NAME=list-of-prices-and-Services-deutsche-bank-ag.pdf
FEE_SCHEDULE_TOOL_JSON=/Users/constantinaldea/IdeaProjects/ai-account-balance/ces-agent/acme_voice_agent/tools/fee_schedule_lookup/fee_schedule_lookup.json
FEE_SCHEDULE_DELETE_BUCKET_ON_DEPROVISION=true

# Optional: local ADC/service-account file path for scripts that need credentials
GCP_SERVICE_ACCOUNT_KEY=/absolute/path/to/google-cloud-credentials.json

# Optional: resolved service URLs for local test helpers
BFA_SERVICE_RESOURCE_URL=https://your-bfa-service-resource-url
BFA_MCP_SPIKE_URL=https://your-bfa-mcp-spike-url

# Optional: deploy-time secret for mock-server
MOCK_API_KEY=replace-me-if-needed

