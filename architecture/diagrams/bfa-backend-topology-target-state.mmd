  %% ═══════════════════════════════════════════════════════════════════
  %% CONNECTIONS — all data flows preserved
  %% ═══════════════════════════════════════════════════════════════════

  %% CES → BFA (single ingress)
  TOOLS ==>|"Private Network Access\n(VPC-SC)"| BFA

  %% BFA → Identity & API LZs
  TKB -->|"RFC 8693\ncustomer token"| CIAM
  TKB -->|"service token\n(Apigee-bound)"| CIDP
  BANK -->|"agentic token"| APIGEE
  CARD -->|"agentic token"| APIGEE
  PROD -->|"service token"| APIGEE
  NBS --> APIGEE
  PFI --> APIGEE

  %% Identity & API → On-Prem
  TKB -.->|"service token\n(Glue-bound)"| EIDP
  LOC -.->|"fallback"| GLUE
  FEE -.->|"fallback"| GLUE
  APPT -.->|"primary"| GLUE
  APIGEE -->|"Hybrid Connectivity\n(Interconnect / VPN)"| CBS

