rvice health status","operationId":"health","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"object"}}}}}}}},"/api/v1/branches":{"get":{"tags":["Location Services"],"summary":"Search branches","description":"Search for bank branches by city, address, postal code, GPS coordinates, or brand.\nAll filter parameters are optional and can be combined.\nSupports multi-brand: Deutsche Bank and Postbank.\n\nResults are always distance-sorted from a reference point:\n- If latitude/longitude provided â sort from those coordinates\n- If only city provided â sort from city centroid (average of all branches in that city)\n- If only postal code provided â sort from postal code centroid\n- Otherwise â sort from the geographic centre of all branch data\n\nThe reference point used is included in the response for transparency.\nData sourced from the Deutsche Bank Filialfinder API.","operationId":"searchBranches","parameters":[{"name":"city","in":"query","description":"City name (case-insensitive, partial match). E.g., 'Frankfurt' matches 'Frankfurt am Main'.","required":false,"schema":{"type":"string"},"example":"KÃ¶ln"},{"name":"address","in":"query","description":"Street name or landmark (partial match, also searches branch names). E.g., 'Alexanderplatz' or 'HauptstraÃe'.","required":false,"schema":{"type":"string"},"example":"HauptstraÃe"},{"name":"postalCode","in":"query","description":"Postal code prefix (matches start of PLZ). E.g., '50' matches all branches in the 50xxx area.","required":false,"schema":{"type":"string"},"example":50667},{"name":"latitude","in":"query","description":"Caller's latitude for distance-based sorting and radius filtering. Must be provided together with longitude.","required":false,"schema":{"type":"number","format":"double"},"example":50.9375},{"name":"longitude","in":"query","description":"Caller's longitude for distance-based sorting and radius filtering. Must be provided together with latitude.","required":false,"schema":{"type":"number","format":"double"},"example":6.9603},{"name":"radiusKm","in":"query","description":"Search radius in kilometres (only applies when lat/lon provided). Default: 50 km.","required":false,"schema":{"type":"number","format":"double"},"example":10.0},{"name":"brand","in":"query","description":"Filter by bank brand. Values: 'Deutsche Bank', 'Postbank'.","required":false,"schema":{"type":"string"},"example":"Deutsche Bank"},{"name":"accessible","in":"query","description":"If true, return only wheelchair-accessible branches.","required":false,"schema":{"type":"boolean"}},{"name":"limit","in":"query","description":"Maximum number of results to return (default: 10, max: 50).","required":false,"schema":{"type":"integer","format":"int32"},"example":5}],"responses":{"400":{"description":"Invalid parameters (e.g., latitude without longitude)","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseBranchSearchResponse"}}}},"403":{"description":"Missing AI_INTERACTION consent","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseBranchSearchResponse"}}}},"200":{"description":"Search results (may be empty if no branches match)","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseBranchSearchResponse"}}}},"401":{"description":"Authentication required","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseBranchSearchResponse"}}}}}}},"/api/v1/branches/{branchId}":{"get":{"tags":["Location Services"],"summary":"Get branch details","description":"Returns full details for a specific branch by its unique identifier.\nIncludes address, opening hours, phone, and accessibility information.\n\nThe opening hours string is in German format and can be parsed by the LLM\nto answer questions like \"Is it open on Saturday?\" or \"What time does it close?\".","operationId":"getBranch","parameters":[{"name":"branchId","in":"path","description":"Unique branch identifier","required":true,"schema":{"type":"string"},"example":"DB-DE-00003"}],"responses":{"200":{"description":"Branch details retrieved","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseBranchDto"}}}},"404":{"description":"Branch not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseBranchDto"}}}},"401":{"description":"Authentication required","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseBranchDto"}}}}}}},"/api/v1/appointments/{appointmentId}":{"get":{"tags":["Advisory Appointment"],"summary":"Get appointment details","operationId":"getAppointment","parameters":[{"name":"appointmentId","in":"path","required":true,"schema":{"type":"string"}},{"name":"appointmentAccessToken","in":"query","description":"Opaque appointment access token","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAppointmentView"}}}}}}},"/api/v1/appointment-taxonomy":{"get":{"tags":["Advisory Appointment"],"summary":"Get appointment taxonomy","operationId":"getAppointmentTaxonomy","parameters":[{"name":"Authorization","in":"header","required":false,"schema":{"type":"string"}},{"name":"X-Mock-Scenario","in":"header","required":false,"schema":{"type":"string"}}],"responses":{"401":{"description":"Authentication required","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAppointmentTaxonomyResponse"}}}},"200":{"description":"Taxonomy returned","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAppointmentTaxonomyResponse"}}}}}}},"/api/v1/appointment-slots":{"get":{"tags":["Advisory Appointment"],"summary":"Get available appointment slots","operationId":"getAppointmentSlots","parameters":[{"name":"entryPath","in":"query","description":"Entry path","required":true,"schema":{"type":"string","enum":["SERVICE_REQUEST","PRODUCT_CONSULTATION"]},"example":"PRODUCT_CONSULTATION"},{"name":"consultationChannel","in":"query","d