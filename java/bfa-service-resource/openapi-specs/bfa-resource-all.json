{"openapi":"3.0.1","info":{"title":"BFA Platform Services API","description":"Backend-for-Agents (BFA) platform services providing shared infrastructure\ncapabilities for agent-based banking operations.\n\n## Scope\nThis service contains platform-level features only:\n- Authentication and authorization (Bearer JWT)\n- Consent management and verification\n- Legitimation (resource-level access control)\n- Audit logging for all operations\n- Location / branch finder services\n- Health check endpoint\n\n## Authentication\nAll endpoints require a Bearer token in the Authorization header.\nAgent context can be passed via X-Agent-Id, X-Tool-Id, X-Session-Id headers.\n\n## Security\n- Consent requirements are declared per endpoint\n- Resource access is verified via legitimation service\n- All operations are audited\n","contact":{"name":"Voice Banking Team","email":"voice-banking@acmebank.example"},"license":{"name":"Internal Use Only","url":"https://acmebank.example/licenses/internal"},"version":"1.0.0"},"servers":[{"url":"http://localhost:8080","description":"Local Development"},{"url":"https://bfa.acmebank.example","description":"Production"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Location Services","description":"Branch and ATM location search for the Voice Banking Assistant"},{"name":"Advisory Appointment","description":"Advisory appointment booking and lifecycle"},{"name":"Health","description":"Service health endpoints"}],"paths":{"/api/v1/appointments":{"post":{"tags":["Advisory Appointment"],"summary":"Create appointment","operationId":"createAppointment","parameters":[{"name":"Authorization","in":"header","required":false,"schema":{"type":"string"}},{"name":"X-Mock-Scenario","in":"header","required":false,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateAppointmentRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCreateAppointmentResponse"}}}}}}},"/api/v1/appointments/{appointmentId}/reschedule":{"post":{"tags":["Advisory Appointment"],"summary":"Reschedule appointment","operationId":"rescheduleAppointment","parameters":[{"name":"appointmentId","in":"path","required":true,"schema":{"type":"string"}},{"name":"Authorization","in":"header","required":false,"schema":{"type":"string"}},{"name":"X-Mock-Scenario","in":"header","required":false,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RescheduleAppointmentRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAppointmentView"}}}}}}},"/api/v1/appointments/{appointmentId}/cancel":{"post":{"tags":["Advisory Appointment"],"summary":"Cancel appointment","operationId":"cancelAppointment","parameters":[{"name":"appointmentId","in":"path","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CancelAppointmentRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAppointmentView"}}}}}}},"/api/v1/services/travel":{"get":{"tags":["non-banking-controller"],"operationId":"getTravelBenefits","parameters":[{"name":"benefitType","in":"query","required":false,"schema":{"type":"string"}},{"name":"cardTier","in":"query","required":false,"schema":{"type":"string","default":"STANDARD"}},{"name":"customerId","in":"query","required":false,"schema":{"type":"string"}},{"name":"lang","in":"query","required":false,"schema":{"type":"string","default":"en"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TravelBenefitsDto"}}}}}}},"/api/v1/services/offers":{"get":{"tags":["non-banking-controller"],"operationId":"getPartnerOffers","parameters":[{"name":"offerType","in":"query","required":false,"s