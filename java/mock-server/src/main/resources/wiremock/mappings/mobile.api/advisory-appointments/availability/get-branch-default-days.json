{
  "priority": 5,
  "request": {
    "method": "GET",
    "urlPath": "/advisory-appointments/availability",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "X-BFA-Client": {
        "matches": ".+"
      }
    },
    "queryParameters": {
      "consultationChannel": {
        "equalTo": "BRANCH"
      },
      "locationId": {
        "equalTo": "20286143"
      },
      "selectedDay": {
        "absent": true
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "mobile.api/advisory-appointments/availability/branch-default-days.json"
  }
}