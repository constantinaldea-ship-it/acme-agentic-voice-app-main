  },
  "evaluations": [
    {
      "name": "appointment_routing_english",
      "owner_agent": "voice_banking_agent",
      "labels": ["root", "routing", "appointment", "english", "langsmith"]
    },
    {
      "name": "appointment_routing_german",
      "owner_agent": "voice_banking_agent",
      "labels": ["root", "routing", "appointment", "german", "langsmith"]
    }
  ]
