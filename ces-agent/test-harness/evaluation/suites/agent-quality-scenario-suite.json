    {
      "name": "branch_search_munich",
      "owner_agent": "location_services_agent",
      "labels": ["subagent", "location", "critical"]
    },
    {
      "name": "fee_schedule_multi_turn",
      "owner_agent": "fee_schedule_agent",
      "labels": ["subagent", "fees", "multi-turn", "critical"]
    },
    {
      "name": "german_branch_search",
      "owner_agent": "location_services_agent",
