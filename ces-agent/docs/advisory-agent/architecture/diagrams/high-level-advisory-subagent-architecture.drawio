                <mxCell id="ces_note" value="&lt;b style=&quot;font-family:Google Sans,Roboto,sans-serif;&quot;&gt;CES design rules&lt;/b&gt;&lt;ul style=&quot;margin:6px 0 0 18px;padding:0;font-size:10px;color:#5F6368;font-family:Roboto,sans-serif;&quot;&gt;&lt;li&gt;Day before time-slot&lt;/li&gt;&lt;li&gt;No generic branch-finder behavior&lt;/li&gt;&lt;li&gt;Lifecycle requires appointmentAccessToken&lt;/li&gt;&lt;/ul&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F4B400;strokeWidth=1.5;fontColor=#202124;fontSize=10;arcSize=10;shadow=0;align=left;verticalAlign=top;spacing=8;" parent="zone1" vertex="1">
