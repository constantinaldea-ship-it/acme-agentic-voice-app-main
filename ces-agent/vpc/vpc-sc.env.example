# or export them in your shell before running vpc/vpc-sc.sh.

# Required
VPC_SC_ACCESS_POLICY_ID=123456789

# Optional overrides
# VPC_SC_PROJECT_NUMBER=1041912723804
# VPC_SC_PROJECTS=projects/1041912723804
# VPC_SC_PERIMETER_NAME=acme_voice_us_perimeter
# VPC_SC_PERIMETER_TITLE=Acme Voice US Perimeter
# VPC_SC_PERIMETER_DESCRIPTION=VPC Service Controls perimeter for the CES banking agent project.

# Recommended baseline for the current CES app
# VPC_SC_RESTRICTED_SERVICES=ces.googleapis.com,contactcenterinsights.googleapis.com,storage.googleapis.com,bigquery.googleapis.com

# Optional access levels and ingress / egress rules
# VPC_SC_ACCESS_LEVELS=accessPolicies/123456789/accessLevels/corp_laptops
# VPC_SC_INGRESS_POLICIES_FILE=/absolute/path/to/ingress-policies.yaml
# VPC_SC_EGRESS_POLICIES_FILE=/absolute/path/to/egress-policies.yaml

# Optional VPC accessible services settings
# VPC_SC_ENABLE_VPC_ACCESSIBLE_SERVICES=true
# VPC_SC_VPC_ALLOWED_SERVICES=RESTRICTED-SERVICES
